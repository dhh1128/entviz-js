# No trailing slash: also ignores a stray `node_modules` SYMLINK (a `node_modules/`
# rule matches directories only, which let an accidental symlink get committed once).
node_modules
dist/
*.log
.DS_Store
__pycache__/

/.tick
.tick.lock

# Generated TypeDoc API reference (run: npm run docs)
docs/api/

# Assembled GitHub Pages publish tree (built in the pages.yml workflow)
/_site/

.worktrees

# Playwright E2E artifacts (run: npm run test:e2e)
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
