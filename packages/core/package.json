{
  "name": "@entviz/core",
  "version": "0.11.0",
  "description": "Visualize high-entropy values as comparable SVG diagrams (entviz, spec v11) — certified against the entviz conformance corpus.",
  "type": "module",
  "main": "src/entviz.ts",
  "types": "src/entviz.ts",
  "exports": {
    ".": "./src/entviz.ts"
  },
  "files": [
    "src",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "entviz-conformance": "src/cli.ts"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:full",
    "test:unit": "node --test --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-lines=80 'test/unit/*.test.ts'",
    "test:full": "node --test --experimental-test-coverage --test-coverage-include='src/**' --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=95 'test/unit/*.test.ts' 'test/integration/*.test.ts'"
  },
  "engines": {
    "node": ">=22.6"
  },
  "keywords": [
    "entviz",
    "entropy",
    "fingerprint",
    "svg",
    "visualization"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhh1128/entviz-js.git"
  }
}
